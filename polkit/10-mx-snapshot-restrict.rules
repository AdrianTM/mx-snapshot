// Restrict the mx-snapshot pkexec helper to be invoked only by a
// caller whose executable's basename is exactly "mx-snapshot" (i.e.
// the frontend binary, regardless of where it's installed). The base
// policy is auth_admin_keep, so matching callers still get the
// password prompt — the rule narrows *who can prompt*, it does not
// skip the prompt.
//
// We deliberately do NOT return polkit.Result.YES anywhere: returning
// YES would skip the auth prompt for the helper, and the helper's
// allow-list includes broad tools (rm, cp, chmod, chown, mount,
// pacman, ...). A blanket "no prompt for any root-owned caller" rule
// was rejected in review — almost every executable in /usr/bin is
// owned by root, so that branch effectively bypasses authentication.
//
// Why basename matching instead of exact /usr/bin/mx-snapshot:
//   - dev builds (./build/mx-snapshot) need to be testable;
//   - readlink -f may resolve through symlinks or snap/flatpak
//     wrappers to non-/usr/bin locations on some installs;
//   - the auth_admin_keep prompt is the real gate — basename
//     matching only filters out unrelated callers (a sysadmin script,
//     a misconfigured launcher), all of whom would still need to
//     enter a password if we let them through.
//
// The CLI helper has its own rules file (10-iso-snapshot-cli-restrict.rules)
// so the mx-snapshot and iso-snapshot-cli .deb packages can be installed
// independently without colliding on this path.
polkit.addRule(function(action, subject) {
    if (action.id != "org.mxlinux.pkexec.mx-snapshot-helper") {
        return; // not our action — let other rules decide
    }

    try {
        var caller_exe = polkit.spawn(["readlink", "-f", "/proc/" + subject.pid + "/exe"]);
        if (typeof caller_exe === "string") {
            // polkit.spawn returns the captured stdout with a trailing
            // newline from readlink; strip whitespace before comparing.
            var path = caller_exe.replace(/\s+$/, "");
            // End-of-string match for "/mx-snapshot" — uses lastIndexOf
            // for compatibility with older SpiderMonkey/duktape engines
            // that may not expose String.prototype.endsWith.
            var suffix = "/mx-snapshot";
            var idx = path.lastIndexOf(suffix);
            if (idx !== -1 && idx === path.length - suffix.length) {
                return polkit.Result.AUTH_ADMIN_KEEP;
            }
        }
    } catch (e) {
        // If the spawn itself fails, fall through to NO.
    }
    return polkit.Result.NO;
});
