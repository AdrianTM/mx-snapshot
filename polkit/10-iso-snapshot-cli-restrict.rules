// Restrict the iso-snapshot-cli pkexec helper to be invoked only by a
// caller whose executable's basename is exactly "iso-snapshot-cli".
// See the mirror file 10-mx-snapshot-restrict.rules for the full
// rationale on basename-vs-exact-path matching and why we never
// return polkit.Result.YES.
//
// Lives in its own file so the mx-snapshot and iso-snapshot-cli .deb
// packages can each ship their own helper rule without colliding on the
// same path under /usr/share/polkit-1/rules.d/. The Arch package
// (single PKGBUILD) is GUI-only and only installs the mx-snapshot rule.
polkit.addRule(function(action, subject) {
    if (action.id != "org.mxlinux.pkexec.iso-snapshot-cli-helper") {
        return; // not our action — let other rules decide
    }

    try {
        var caller_exe = polkit.spawn(["readlink", "-f", "/proc/" + subject.pid + "/exe"]);
        if (typeof caller_exe === "string") {
            var path = caller_exe.replace(/\s+$/, "");
            var suffix = "/iso-snapshot-cli";
            var idx = path.lastIndexOf(suffix);
            if (idx !== -1 && idx === path.length - suffix.length) {
                return polkit.Result.AUTH_ADMIN_KEEP;
            }
        }
    } catch (e) {
        // If the spawn itself fails, fall through to NO.
    }
    return polkit.Result.NO;
});
